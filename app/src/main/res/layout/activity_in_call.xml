<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Foto del contacto -->
    <FrameLayout
        android:id="@+id/avatar_container"
        android:layout_width="96dp"
        android:layout_height="96dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.18"
        app:layout_constraintBottom_toTopOf="@id/tv_caller_name">

        <!-- Inicial de respaldo -->
        <TextView
            android:id="@+id/tv_avatar_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="36sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_avatar" />

        <!-- Foto real -->
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar"
            android:contentDescription="Foto de contacto" />
    </FrameLayout>

    <!-- Nombre -->
    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="28sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/poppins_semibold"
        android:paddingHorizontal="32dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/avatar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_call_status" />

    <!-- Estado -->
    <TextView
        android:id="@+id/tv_call_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="@font/poppins_regular"
        android:paddingTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controls_row" />

    <!-- Controles: Mute + Altavoz -->
    <LinearLayout
        android:id="@+id/controls_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingVertical="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_call_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_end_call">

        <LinearLayout
            android:id="@+id/btn_mute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ic_mute"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_mute"
                android:background="@drawable/bg_key_circle"
                android:padding="16dp"
                android:alpha="0.5"
                android:contentDescription="Silenciar" />
            <TextView
                android:id="@+id/tv_mute_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mute_off"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/poppins_regular"
                android:paddingTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_speaker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ic_speaker"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_speaker"
                android:background="@drawable/bg_key_circle"
                android:padding="16dp"
                android:alpha="0.5"
                android:contentDescription="Altavoz" />
            <TextView
                android:id="@+id/tv_speaker_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/speaker_off"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/poppins_regular"
                android:paddingTop="8dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Botón colgar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_end_call"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_call_end"
        android:contentDescription="Colgar"
        app:backgroundTint="@color/red"
        app:tint="@color/text_primary"
        app:fabSize="normal"
        android:layout_marginBottom="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
