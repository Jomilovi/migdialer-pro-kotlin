<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <TextView
        android:id="@+id/tv_sim_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_sim_badge"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:textColor="@color/sim1"
        android:textSize="12sp"
        android:fontFamily="@font/poppins"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_call_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/poppins"
        android:letterSpacing="0.05"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="00:00"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/mono"
        android:letterSpacing="0.06"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/caller_avatar"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_timer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_avatar_initial_incall"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_avatar_incall"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/bg_primary"
            android:textSize="36sp"
            android:fontFamily="@font/poppins_bold" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:fontFamily="@font/poppins_semibold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/caller_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_caller_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:fontFamily="@font/poppins"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/answer_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="40dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btn_hang_up"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_reject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            android:src="@drawable/ic_call_missed"
            app:backgroundTint="@color/red"
            app:tint="@color/text_primary"
            app:fabSize="normal" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_answer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_call"
            app:backgroundTint="@color/green"
            app:tint="@color/text_primary"
            app:fabSize="normal" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/control_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:columnCount="4"
        android:rowCount="1"
        app:layout_constraintBottom_toTopOf="@id/btn_hang_up"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btn_mute"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/ic_mute"
                android:padding="14dp"
                android:alpha="0.5"
                android:contentDescription="Silencio" />

            <TextView
                android:id="@+id/tv_mute_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Silencio"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/poppins" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btn_speaker"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/ic_speaker"
                android:padding="14dp"
                android:alpha="0.5"
                android:contentDescription="Altavoz" />

            <TextView
                android:id="@+id/tv_speaker_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Altavoz"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/poppins" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btn_hold"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/ic_hold"
                android:padding="14dp"
                android:alpha="0.5"
                android:contentDescription="Espera" />

            <TextView
                android:id="@+id/tv_hold_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Espera"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/poppins" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btn_dtmf"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_control_button"
                android:src="@drawable/ic_dialpad"
                android:padding="14dp"
                android:alpha="0.5"
                android:contentDescription="Teclado" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Teclado"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/poppins" />
        </LinearLayout>

    </GridLayout>

    <GridLayout
        android:id="@+id/dtmf_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="48dp"
        android:layout_marginBottom="8dp"
        android:columnCount="3"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/control_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/dtmf_1" style="@style/DtmfKey" android:text="1" />
        <Button android:id="@+id/dtmf_2" style="@style/DtmfKey" android:text="2" />
        <Button android:id="@+id/dtmf_3" style="@style/DtmfKey" android:text="3" />
        <Button android:id="@+id/dtmf_4" style="@style/DtmfKey" android:text="4" />
        <Button android:id="@+id/dtmf_5" style="@style/DtmfKey" android:text="5" />
        <Button android:id="@+id/dtmf_6" style="@style/DtmfKey" android:text="6" />
        <Button android:id="@+id/dtmf_7" style="@style/DtmfKey" android:text="7" />
        <Button android:id="@+id/dtmf_8" style="@style/DtmfKey" android:text="8" />
        <Button android:id="@+id/dtmf_9" style="@style/DtmfKey" android:text="9" />
        <Button android:id="@+id/dtmf_star" style="@style/DtmfKey" android:text="*" />
        <Button android:id="@+id/dtmf_0" style="@style/DtmfKey" android:text="0" />
        <Button android:id="@+id/dtmf_hash" style="@style/DtmfKey" android:text="#" />
    </GridLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_hang_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="56dp"
        android:src="@drawable/ic_call_missed"
        android:contentDescription="Colgar"
        app:backgroundTint="@color/red"
        app:tint="@color/text_primary"
        app:fabSize="normal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
