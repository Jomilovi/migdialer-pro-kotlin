<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <TextView
        android:id="@+id/tv_sim_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_sim_badge"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:textColor="@color/sim1"
        android:textSize="12sp"
        android:fontFamily="@font/poppins"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_incoming_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="Llamada entrante"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/poppins"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/avatar_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_incoming_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_avatar_ring"
            android:alpha="0.15" />

        <TextView
            android:id="@+id/tv_avatar_initial"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_avatar_incall"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/bg_primary"
            android:textSize="38sp"
            android:fontFamily="@font/poppins_bold" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="Desconocido"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:fontFamily="@font/poppins_semibold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/avatar_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_caller_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:fontFamily="@font/poppins"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/answer_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="56dp"
        android:layout_marginHorizontal="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_decline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_call_missed"
                android:contentDescription="Rechazar"
                app:backgroundTint="@color/red"
                app:tint="@color/text_primary"
                app:fabSize="normal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Rechazar"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="0.5" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_answer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_call"
                android:contentDescription="Contestar"
                app:backgroundTint="@color/green"
                app:tint="@color/text_primary"
                app:fabSize="normal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Contestar"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
